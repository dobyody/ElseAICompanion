# Else AI Companion — Configurare Backend
# Copiază acest fișier în .env și completează valorile

# ── Moodle ───────────────────────────────────────────────────────────────────
# URL-ul instalației tale Moodle    (ex: https://else.fcim.utm.md)
MOODLE_URL=https://else.fcim.utm.md
# Token-ul 
MOODLE_TOKEN=------------------

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# ── RAG ──────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=8000
# Pentru development: permite orice origin
# În producție: specifică originul Moodle, ex: https://else.fcim.utm.md
CORS_ORIGINS=*
